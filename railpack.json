{
  "$schema": "https://schema.railpack.com",
  "provider": "python",
  "packages": {
    "node": "22"
  },
  "steps": {
    "pgclient16": {
      "commands": [
        {
          "src": "scripts/build_pgclient16.sh",
          "dest": "build_pgclient16.sh"
        },
        "bash build_pgclient16.sh"
      ]
    }
  },
  "deploy": {
    "inputs": [
      "...",
      {
        "step": "pgclient16",
        "include": ["/opt/pgclient"]
      }
    ],
    "paths": ["/opt/pgclient/bin"]
  }
}
